# Checked-in upstream dependency defaults. Prefer putting qbit provider
# coordinates in .env; these qbit values are retained for direct Compose users.

QBIT_GIT_URL=https://github.com/Qbit-Org/qbit.git
QBIT_GIT_REF=main
# Optional exact qbit pin for reproducible bootstrap runs:
QBIT_GIT_COMMIT=

CKPOOL_GIT_URL=https://bitbucket.org/ckolivas/ckpool.git
CKPOOL_GIT_REF=88e99e0b6fc7e28796c8450b42fa00070b66c6e3

CPUMINER_GIT_URL=https://github.com/JayDDee/cpuminer-opt.git
CPUMINER_GIT_REF=b34565bfaca5da9ed894a326e3ba0dfe459550a4

BITCOIN_RELEASE_VERSION=30.2
BITCOIN_RELEASE_BASE_URL=https://bitcoincore.org/bin/bitcoin-core-30.2
BITCOIN_RELEASE_URL=
