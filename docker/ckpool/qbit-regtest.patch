+static void send_json_result(sdata_t *sdata, const int64_t client_id, json_t *id_val,
+			     json_t *result_val, const int msg_type)
+{
+	json_t *val = json_object();
+
+	json_object_set_new_nocheck(val, "result", result_val);
+	json_object_set_nocheck(val, "id", id_val);
+	json_object_set_new_nocheck(val, "error", json_null());
+	stratum_add_send(sdata, val, client_id, msg_type);
+}
+
+static bool parse_version_rolling_mask(uint32_t *mask, const char *mask_str)
+{
+	if (!mask_str || strlen(mask_str) != 8 || !validhex(mask_str))
+		return false;
+	sscanf(mask_str, "%x", mask);
+	return true;
+}
+
+static json_t *configure_result(ckpool_t *ckp, stratum_instance_t *client, const json_t *params_val)
+{
+	json_t *extensions_val, *extension_params, *result_val, *arr_val;
+	size_t index;
+
+	result_val = json_object();
+	if (!json_is_array(params_val))
+		return result_val;
+
+	extensions_val = json_array_get(params_val, 0);
+	if (!json_is_array(extensions_val))
+		return result_val;
+
+	extension_params = json_array_get(params_val, 1);
+	if (!json_is_object(extension_params))
+		extension_params = NULL;
+
+	json_array_foreach(extensions_val, index, arr_val) {
+		const char *extension = json_string_value(arr_val);
+
+		if (!extension || !strlen(extension))
+			continue;
+
+		if (!safecmp(extension, "version-rolling")) {
+			const char *miner_mask_str = NULL;
+			json_t *miner_mask_val = NULL;
+			uint32_t miner_mask = 0xffffffff;
+			uint32_t negotiated_mask = 0;
+			char version_str[12];
+
+			if (extension_params) {
+				miner_mask_val = json_object_get(extension_params, "version-rolling.mask");
+				miner_mask_str = json_string_value(miner_mask_val);
+				if (miner_mask_val && !parse_version_rolling_mask(&miner_mask, miner_mask_str)) {
+					json_set_bool(result_val, "version-rolling", false);
+					json_set_string(result_val, "version-rolling.mask", "00000000");
+					client->version_rolling_mask = 0;
+					continue;
+				}
+			}
+
+			negotiated_mask = miner_mask & ckp->version_mask;
+			client->version_rolling_mask = negotiated_mask;
+			sprintf(version_str, "%08x", negotiated_mask);
+			json_set_bool(result_val, "version-rolling", negotiated_mask != 0);
+			json_set_string(result_val, "version-rolling.mask", version_str);
+			continue;
+		}
+
+		json_set_bool(result_val, extension, false);
+	}
+
+	return result_val;
+}
