QBIT_PROVIDER=source
QBIT_SRC_DIR=/absolute/path/to/qbit
QBIT_BIN_DIR=
# Set QBIT_PROVIDER=git to clone and stage qbit from git.
# Configure these here or in config/upstream.env; .env values override upstream.
# QBIT_GIT_URL=
# QBIT_GIT_REF=
# QBIT_GIT_COMMIT=
# Leave QBIT_SRC_DIR as-is when QBIT_PROVIDER=git.

QBIT_CHAIN=regtest
QBIT_CHAIN_FLAG=-regtest
QBIT_NODE_EXTRA_ARG=-asert
QBIT_LISTEN=0
QBIT_RPC_USER=qbitrpc
QBIT_RPC_PASSWORD=change-this
QBIT_RPC_PORT=18452
QBIT_P2P_PORT=18460
QBIT_RPC_PORT_HOST=127.0.0.1:18452
QBIT_P2P_PORT_HOST=127.0.0.1:18460
QBIT_ZMQ_BLOCK_PORT_HOST=127.0.0.1:28332
QBIT_ZMQ_TX_PORT_HOST=127.0.0.1:28333
QBIT_MINER_ADDRESS=auto
MINER_TIMEOUT_SECONDS=180
MINER_USERNAME_TIMEOUT_SECONDS=120

CKPOOL_STRATUM_PORT_HOST=3333
CKPOOL_MINDIFF=
CKPOOL_STARTDIFF=
CKPOOL_MAXDIFF=
CKPOOL_PUBLIC_DIFF_POLICY=explicit
CKPOOL_LOG_DIR=/var/log/ckpool
CKPOOL_SOCK_DIR=/tmp/qbitlab
# Used only by the optional ckpool-real service.
CKPOOL_REAL_LOG_DIR=/var/log/ckpool
CKPOOL_REAL_SOCK_DIR=/tmp/qbitlab-real
CKPOOL_NOTIFY=false
CKPOOL_BTCSIG=/qbit-operator-lab/
CKPOOL_BLOCKPOLL=2
CKPOOL_DONATION=0.0
CKPOOL_NONCE1LENGTH=4
CKPOOL_NONCE2LENGTH=8
CKPOOL_UPDATE_INTERVAL=30
CKPOOL_NON_TEST_READINESS_GATE=1
CKPOOL_MIN_PEERS=1
CKPOOL_PREFLIGHT_RPC_TIMEOUT_SECONDS=5
CKPOOL_PREFLIGHT_READINESS_TIMEOUT_SECONDS=120
CKPOOL_VALIDATE_QBIT_ASSUMPTIONS=1
CKPOOL_REQUIRE_P2MR_PAYOUT=
QBIT_EXPECTED_ADDRESS_HRP=
QBIT_EXPECTED_MAX_BLOCK_WEIGHT=2000000
QBIT_EXPECTED_WITNESS_SCALE_FACTOR=1
QBIT_EXPECTED_COINBASE_MATURITY=1000
# dynamic makes ckpool use qbit getblocktemplate.versionrollingmask when present.
# Older qbitd builds without that field fall back to CKPOOL_VERSION_MASK.
# Use 1fffe000 for the qbit permissionless path; keep low-byte masks for
# isolated legacy/genesis tests only.
CKPOOL_VERSION_MASK_MODE=dynamic
CKPOOL_VERSION_MASK=1fffe000
CKPOOL_VERSION_MASK_RPC_TIMEOUT_SECONDS=5

BITCOIN_CHAIN_FLAG=-regtest
BITCOIN_RPC_USER=bitcoinrpc
BITCOIN_RPC_PASSWORD=change-this
BITCOIN_RPC_PORT=18443
BITCOIN_P2P_PORT=18444
BITCOIN_RPC_PORT_HOST=127.0.0.1:18443
BITCOIN_P2P_PORT_HOST=127.0.0.1:18446
# Regtest lab defaults keep parent-chain peer discovery disabled. Override
# these for a public parent-chain node, or use BITCOIN_NODE_EXTRA_ARGS below.
BITCOIN_DNSSEED=0
# Optional: discover and advertise this node's reachable address.
BITCOIN_DISCOVER=0
# Whitespace-separated bitcoind flags appended after the compose defaults.
# Example: BITCOIN_NODE_EXTRA_ARGS="-dnsseed=1 -addnode=host:48333"
BITCOIN_NODE_EXTRA_ARGS=
BITCOIN_MINER_ADDRESS=auto
BITCOIN_MINER_WALLET_NAME=auxpow-parent

UBUNTU_VERSION=24.04
COMPOSE_PROJECT_NAME=qbit-operator-lab
AUXPOW_BRIDGE_INTERVAL_SECONDS=15
AUXPOW_STRATUM_PORT_HOST=3335
AUXPOW_STRATUM_SHARE_DIFF=1
AUXPOW_STRATUM_VARDIFF_ENABLED=1
AUXPOW_STRATUM_VARDIFF_TARGET_SHARE_SECONDS=5
AUXPOW_STRATUM_VARDIFF_TARGET_SHARES_PER_SECOND=
AUXPOW_STRATUM_VARDIFF_MIN_DIFF=1024
AUXPOW_STRATUM_VARDIFF_MAX_DIFF=4294967296
AUXPOW_STRATUM_VARDIFF_RETARGET_SECONDS=120
AUXPOW_STRATUM_VARDIFF_MAX_STEP_FACTOR=4
AUXPOW_STRATUM_VARDIFF_MAX_STEP_DOWN_FACTOR=2
AUXPOW_STRATUM_VARDIFF_EWMA_ALPHA=0.4
AUXPOW_STRATUM_VARDIFF_RETARGET_TOLERANCE=0.25
AUXPOW_STRATUM_VARDIFF_STARTUP_DIFF=8192
AUXPOW_STRATUM_VARDIFF_APPLY_MODE=next_job
AUXPOW_STRATUM_POLL_SECONDS=5
AUXPOW_STRATUM_JOB_MAX_AGE_SECONDS=2700
AUXPOW_STRATUM_VERSION_MASK=1fffe000
AUXPOW_STRATUM_HEADER_VARIANT=canonical
AUXPOW_STRATUM_DIAG_JSONL=0
AUXPOW_STRATUM_DIAG_EVENTS=0
AUXPOW_STRATUM_DIAG_VARIANTS=0
AUXPOW_STRATUM_ACCEPT_DIAGNOSTIC_VARIANT=0
AUXPOW_STRATUM_STATS_INTERVAL_SECONDS=60
# Optional JSON map of Stratum username to expected hashes/sec for share-rate diagnostics.
AUXPOW_STRATUM_EXPECTED_HASHRATES=
AUXPOW_MINER_USERNAME=auxpow-smoke
AUXPOW_MINER_PASSWORD=x
AUXPOW_REAL_MINER_THREADS=1
AUXPOW_REAL_MINER_TIMEOUT_SECONDS=120

# Signet overrides:
# QBIT_CHAIN=signet
# QBIT_CHAIN_FLAG=-signet
# QBIT_NODE_EXTRA_ARG=-signetchallenge=<your_signet_challenge_hex>
# QBIT_LISTEN=0
# QBIT_RPC_PORT=38352
# QBIT_P2P_PORT=38355
# QBIT_RPC_PORT_HOST=127.0.0.1:38352
# QBIT_P2P_PORT_HOST=127.0.0.1:38355
# QBIT_MINER_ADDRESS=auto
# CKPOOL_MINDIFF=<reviewed-share-floor>
# CKPOOL_STARTDIFF=<reviewed-starting-share-difficulty>
# CKPOOL_MAXDIFF=<optional-share-difficulty-cap>
#
# qbitd stays private by default. To intentionally run a reachable qbit peer,
# set QBIT_LISTEN=1 and publish QBIT_P2P_PORT_HOST=0.0.0.0:<p2p-port>.
#
# Optional live parent-chain overrides for AuxPoW operator mode:
# BITCOIN_RPC_HOST=<your_parent_node_host>
# BITCOIN_RPC_PORT=<your_parent_node_rpc_port>
# BITCOIN_RPC_USER=<your_parent_node_rpc_user>
# BITCOIN_RPC_PASSWORD=<your_parent_node_rpc_password>
# BITCOIN_MINER_ADDRESS=<your_bitcoin_payout_address>
#
# Local Bitcoin testnet4 parent-node example:
# BITCOIN_CHAIN_FLAG=-testnet4
# BITCOIN_RPC_PORT=48332
# BITCOIN_P2P_PORT=48333
# BITCOIN_RPC_PORT_HOST=127.0.0.1:48332
# BITCOIN_P2P_PORT_HOST=127.0.0.1:48333
# BITCOIN_DNSSEED=1
# BITCOIN_DISCOVER=0
# BITCOIN_NODE_EXTRA_ARGS=
# BITCOIN_MINER_ADDRESS=<your_bitcoin_testnet4_payout_address>
#
# Equivalent discovery override using the general extra-args hook:
# BITCOIN_NODE_EXTRA_ARGS="-dnsseed=1"
