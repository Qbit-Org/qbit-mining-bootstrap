QBIT_PROVIDER=git
QBIT_PRODUCTION=0
# Alias accepted by qbit-tools style wrappers.
QBIT_TOOLS_PRODUCTION=0
QBIT_SRC_DIR=/absolute/path/to/qbit
QBIT_BIN_DIR=
# The public default clones qbit from GitHub and stages it under generated/.
# To use a local checkout instead, set QBIT_PROVIDER=source and QBIT_SRC_DIR.
QBIT_GIT_URL=https://github.com/Qbit-Org/qbit.git
QBIT_GIT_REF=main
QBIT_GIT_COMMIT=
# Leave QBIT_SRC_DIR as-is when QBIT_PROVIDER=git.

QBIT_CHAIN=regtest
QBIT_CHAIN_FLAG=-regtest
QBIT_NODE_EXTRA_ARG=-asert
QBIT_LISTEN=0
QBIT_RPC_USER=qbitrpc
QBIT_RPC_PASSWORD=change-this
QBIT_RPC_PORT=18452
QBIT_P2P_PORT=18460
QBIT_RPC_PORT_HOST=127.0.0.1:18452
QBIT_P2P_PORT_HOST=127.0.0.1:18460
QBIT_ZMQ_BLOCK_PORT_HOST=127.0.0.1:28332
QBIT_ZMQ_TX_PORT_HOST=127.0.0.1:28333
QBIT_MINER_ADDRESS=auto
MINER_TIMEOUT_SECONDS=180
MINER_USERNAME_TIMEOUT_SECONDS=120

CKPOOL_STRATUM_PORT_HOST=3333
CKPOOL_MINDIFF=
CKPOOL_STARTDIFF=
CKPOOL_MAXDIFF=
CKPOOL_PUBLIC_DIFF_POLICY=explicit
CKPOOL_LOG_DIR=/var/log/ckpool
CKPOOL_SOCK_DIR=/tmp/qbitlab
# Used only by the optional ckpool-real service.
CKPOOL_REAL_LOG_DIR=/var/log/ckpool
CKPOOL_REAL_SOCK_DIR=/tmp/qbitlab-real
CKPOOL_NOTIFY=false
# Set this explicitly empty to omit ckpool's optional coinbase signature.
CKPOOL_BTCSIG=/qbit-mining-bootstrap/
CKPOOL_BLOCKPOLL=2
CKPOOL_DONATION=0.0
CKPOOL_NONCE1LENGTH=4
CKPOOL_NONCE2LENGTH=8
CKPOOL_UPDATE_INTERVAL=30
CKPOOL_NON_TEST_READINESS_GATE=1
CKPOOL_MIN_PEERS=1
CKPOOL_PREFLIGHT_RPC_TIMEOUT_SECONDS=5
CKPOOL_PREFLIGHT_READINESS_TIMEOUT_SECONDS=120
CKPOOL_VALIDATE_QBIT_ASSUMPTIONS=1
CKPOOL_REQUIRE_P2MR_PAYOUT=
QBIT_EXPECTED_ADDRESS_HRP=
QBIT_EXPECTED_MAX_BLOCK_WEIGHT=2000000
QBIT_EXPECTED_WITNESS_SCALE_FACTOR=1
QBIT_EXPECTED_COINBASE_MATURITY=1000
# dynamic makes ckpool use qbit getblocktemplate.versionrollingmask when present.
# Older qbitd builds without that field fall back to CKPOOL_VERSION_MASK.
# Direct qbit Stratum services use their own configured fallback masks:
# CKPOOL_VERSION_MASK for ckpool, PRISM_VERSION_ROLLING_MASK for PRISM, and
# AUXPOW_STRATUM_VERSION_MASK for parent-chain AuxPoW Stratum.
# Current qbitd permissionless templates advertise 1fffe000; keep dynamic mode
# enabled so the node remains authoritative when that changes.
CKPOOL_VERSION_MASK_MODE=dynamic
CKPOOL_VERSION_MASK=1fffe000
CKPOOL_VERSION_MASK_RPC_TIMEOUT_SECONDS=5

BITCOIN_CHAIN_FLAG=-regtest
BITCOIN_RPC_USER=bitcoinrpc
BITCOIN_RPC_PASSWORD=change-this
BITCOIN_RPC_PORT=18443
BITCOIN_P2P_PORT=18444
BITCOIN_RPC_PORT_HOST=127.0.0.1:18443
BITCOIN_P2P_PORT_HOST=127.0.0.1:18446
# Regtest lab defaults keep parent-chain peer discovery disabled. Override
# these for a public parent-chain node, or use BITCOIN_NODE_EXTRA_ARGS below.
BITCOIN_DNSSEED=0
# Optional: discover and advertise this node's reachable address.
BITCOIN_DISCOVER=0
# Whitespace-separated bitcoind flags appended after the compose defaults.
# Example: BITCOIN_NODE_EXTRA_ARGS="-dnsseed=1 -addnode=host:48333"
BITCOIN_NODE_EXTRA_ARGS=
BITCOIN_MINER_ADDRESS=auto
BITCOIN_MINER_WALLET_NAME=auxpow-parent

UBUNTU_VERSION=24.04
COMPOSE_PROJECT_NAME=qbit-mining-bootstrap
AUXPOW_BRIDGE_INTERVAL_SECONDS=15
AUXPOW_STRATUM_PORT_HOST=3335
AUXPOW_STRATUM_SHARE_DIFF=1
AUXPOW_STRATUM_VARDIFF_ENABLED=1
AUXPOW_STRATUM_VARDIFF_TARGET_SHARE_SECONDS=5
AUXPOW_STRATUM_VARDIFF_TARGET_SHARES_PER_SECOND=
AUXPOW_STRATUM_VARDIFF_MIN_DIFF=1024
AUXPOW_STRATUM_VARDIFF_MAX_DIFF=4294967296
AUXPOW_STRATUM_VARDIFF_RETARGET_SECONDS=120
AUXPOW_STRATUM_VARDIFF_MAX_STEP_FACTOR=4
AUXPOW_STRATUM_VARDIFF_MAX_STEP_DOWN_FACTOR=2
AUXPOW_STRATUM_VARDIFF_EWMA_ALPHA=0.4
AUXPOW_STRATUM_VARDIFF_RETARGET_TOLERANCE=0.25
AUXPOW_STRATUM_VARDIFF_STARTUP_DIFF=8192
AUXPOW_STRATUM_VARDIFF_APPLY_MODE=next_job
AUXPOW_STRATUM_POLL_SECONDS=5
AUXPOW_STRATUM_JOB_MAX_AGE_SECONDS=2700
AUXPOW_STRATUM_VERSION_MASK=1fffe000
AUXPOW_STRATUM_HEADER_VARIANT=canonical
AUXPOW_STRATUM_DIAG_JSONL=0
AUXPOW_STRATUM_DIAG_EVENTS=0
AUXPOW_STRATUM_DIAG_VARIANTS=0
AUXPOW_STRATUM_ACCEPT_DIAGNOSTIC_VARIANT=0
AUXPOW_STRATUM_STATS_INTERVAL_SECONDS=60
# Optional JSON map of Stratum username to expected hashes/sec for share-rate diagnostics.
AUXPOW_STRATUM_EXPECTED_HASHRATES=
AUXPOW_MINER_USERNAME=auxpow-smoke
AUXPOW_MINER_PASSWORD=x
AUXPOW_REAL_MINER_THREADS=1
AUXPOW_REAL_MINER_TIMEOUT_SECONDS=120

# Direct PRISM Stratum. Production should use Postgres, real signing seeds, and
# a trusted ledger public key distributed out of band from audit bundles.
PRISM_STRATUM_BIND=0.0.0.0
PRISM_STRATUM_PORT=3340
PRISM_STRATUM_PORT_HOST=3340
PRISM_AUDIT_BIND=127.0.0.1
PRISM_AUDIT_PORT=3341
PRISM_AUDIT_DIR=/var/lib/qbit-prism/audit
PRISM_AUDIT_SHARE_SEGMENT_SIZE=10000
PRISM_AUDIT_LIVE_BUNDLE_RETENTION=5
PRISM_AUDIT_CANDIDATE_RETENTION_SECONDS=86400
PRISM_CTV_BROADCAST_ATTEMPT_DETAIL_LIMIT=20
PRISM_CTV_BROADCAST_RETRY_BACKOFF_SECONDS=300
PRISM_EVIDENCE_PATH=/var/lib/qbit-prism/audit/prism-live-evidence.json
PRISM_STOP_AFTER_BLOCK=0
PRISM_MAX_BLOCKS=2147483647
PRISM_BLOCKPOLL_SECONDS=2
PRISM_BLOCKWAIT_ENABLED=1
PRISM_BLOCKWAIT_TIMEOUT_SECONDS=5
PRISM_REORG_RECONCILER_ENABLED=1
PRISM_VERSION_ROLLING_MASK=1fffe000
PRISM_COINBASE_TAG=/PRISM/
PRISM_PUBLIC_POOL_NAME=PRISM
PRISM_PUBLIC_STRATUM_HOST=
PRISM_PUBLIC_STRATUM_URL=
# Optional external URL for the high-diff endpoint in /public/v1/mining-configuration.
# Used only when PRISM_STRATUM_HIGHDIFF_PORT is set; empty derives from
# PRISM_PUBLIC_STRATUM_URL first, then PRISM_PUBLIC_STRATUM_HOST, plus
# PRISM_STRATUM_HIGHDIFF_PORT.
PRISM_PUBLIC_STRATUM_HIGHDIFF_URL=
PRISM_PUBLIC_POOL_FEE_BPS=0
PRISM_PUBLIC_CONFIGURATION_LABEL="PRISM default"
PRISM_PUBLIC_CONFIGURATION_DESCRIPTION=
PRISM_PUBLIC_BLOCK_TEMPLATE_POLICY="pool-selected qbit block template with PRISM payout settlement"
PRISM_PUBLIC_MINIMUM_PAYOUT_BITS=
PRISM_PUBLIC_EXPLORER_TX_URL_PREFIX=
PRISM_PUBLIC_EXPLORER_BLOCK_URL_PREFIX=
PRISM_PUBLIC_CACHE_ENABLED=1
PRISM_PUBLIC_CACHE_TTL_SECONDS=5
PRISM_PUBLIC_CACHE_STALE_WHILE_REVALIDATE_SECONDS=30
PRISM_PUBLIC_CONFIG_CACHE_TTL_SECONDS=300
PRISM_PUBLIC_CONFIG_CACHE_STALE_WHILE_REVALIDATE_SECONDS=3600
PRISM_PUBLIC_ARTIFACT_CACHE_TTL_SECONDS=86400
PRISM_PUBLIC_ARTIFACT_CACHE_STALE_WHILE_REVALIDATE_SECONDS=86400
PRISM_PUBLIC_CACHE_MAX_ENTRIES=512
PRISM_PUBLIC_CACHE_MAX_RESPONSE_BYTES=1048576
PRISM_PUBLIC_CACHE_DEBUG_HEADERS=0
PRISM_STRATUM_EXTRANONCE2_SIZE=8
PRISM_STRATUM_SHARE_DIFF=0.000000001
PRISM_STRATUM_SHARE_WEIGHT=1
PRISM_STRATUM_SHARE_WEIGHTS_JSON=
PRISM_STRATUM_VARDIFF=1
PRISM_STRATUM_VARDIFF_TARGET_SECONDS=15
PRISM_STRATUM_VARDIFF_MIN_DIFF=0.000000001
PRISM_STRATUM_VARDIFF_MAX_DIFF=1024
PRISM_STRATUM_VARDIFF_RETARGET_SECONDS=90
PRISM_STRATUM_VARDIFF_MAX_STEP_UP=4
PRISM_STRATUM_VARDIFF_MAX_STEP_DOWN=4
PRISM_STRATUM_VARDIFF_START_DIFF=0.000000001
PRISM_STRATUM_VARDIFF_EWMA_ALPHA=0.4
PRISM_STRATUM_VARDIFF_RETARGET_TOLERANCE=0.25
# Set to 0 to disable idle zero-share vardiff step-down sweeps.
PRISM_STRATUM_VARDIFF_IDLE_SWEEP_SECONDS=15
PRISM_STRATUM_STALE_GRACE_SECONDS=3
PRISM_WORKER_METRICS_LIMIT=100
# Optional second Stratum listener for rental-scale miners (e.g. NiceHash
# orders, which require a >=500000 share difficulty from the first
# mining.set_difficulty they see). Disabled unless PRISM_STRATUM_HIGHDIFF_PORT
# is set. Difficulty bounds are independent of the default listener; all other
# vardiff knobs (target/retarget/steps) inherit PRISM_STRATUM_VARDIFF_*.
# Clients may raise (never lower) their difficulty within these bounds via the
# password convention d=N,md=N or mining.suggest_difficulty.
PRISM_STRATUM_HIGHDIFF_PORT=
# Host publish mapping for the high-diff listener. Leave empty while the
# listener is disabled (compose then maps an ephemeral loopback port so host
# 4334 is never occupied); set to 4334 together with
# PRISM_STRATUM_HIGHDIFF_PORT when enabling it.
PRISM_STRATUM_HIGHDIFF_PORT_HOST=
PRISM_STRATUM_HIGHDIFF_BIND=
PRISM_STRATUM_HIGHDIFF_START_DIFF=500000
# MIN_DIFF is a wire guarantee: stamped jobs advertise at least this value
# even while qbit network difficulty is below it (young chain, test networks),
# because marketplace verification judges the first mining.set_difficulty.
PRISM_STRATUM_HIGHDIFF_MIN_DIFF=500000
PRISM_STRATUM_HIGHDIFF_MAX_DIFF=4294967296
# Fixed difficulty when vardiff is disabled; empty tracks
# PRISM_STRATUM_HIGHDIFF_START_DIFF and must stay within [MIN_DIFF, MAX_DIFF].
PRISM_STRATUM_HIGHDIFF_SHARE_DIFF=
PRISM_MIN_READY_MINERS=3
# Empty means testnet/signet chains use the built-in tq fallback address, while
# regtest and mainnet keep invalid usernames fail-closed unless explicitly set.
PRISM_USERNAME_FALLBACK_ADDRESS=
# Fixed absolute miner payout floor. Empty uses the formula inputs below.
PRISM_PAYOUT_MIN_OUTPUT_SATS=
PRISM_PAYOUT_P2MR_SPEND_INPUT_BYTES=3680
PRISM_PAYOUT_TARGET_FEERATE_SATS_PER_BYTE=1
PRISM_PAYOUT_SAFETY_MULTIPLIER=4
PRISM_POOL_FEE_ENABLED=0
PRISM_POOL_FEE_BPS=
# Configure either a qbit P2MR fee address or a raw 32-byte P2MR program.
PRISM_POOL_FEE_ADDRESS=
PRISM_POOL_FEE_P2MR_PROGRAM_HEX=
PRISM_POOL_FEE_RECIPIENT_ID=
PRISM_POOL_FEE_ORDER_KEY=
PRISM_POSTGRES_IMAGE=postgres:16-alpine
PRISM_POSTGRES_DB=qbit
PRISM_POSTGRES_USER=qbit
PRISM_POSTGRES_PASSWORD=change-this
PRISM_DATABASE_URL=postgresql://qbit:change-this@prism-postgres:5432/qbit
PRISM_POSTGRES_PSQL_COMMAND=
PRISM_POSTGRES_INIT_SCHEMA=1
PRISM_POSTGRES_READ_CONCURRENCY=4
PRISM_LEDGER_WRITER_ID=prism-coordinator
PRISM_LEDGER_WRITER_EPOCH=1
PRISM_LEDGER_WRITER_SESSION_TOKEN=
PRISM_LEDGER_WRITER_PUBLIC_KEY_HEX=
PRISM_MANIFEST_SIGNING_SEED_HEX=
PRISM_LEDGER_ATTESTATION_SIGNING_SEED_HEX=
PRISM_ALLOW_MEMORY_LEDGER=0
PRISM_ALLOW_TEST_SIGNING_SEEDS=0
PRISM_ALLOW_BUNDLE_EMBEDDED_LEDGER_KEY=0
PRISM_ALLOW_FIXED_LEDGER_SESSION_TOKEN=0

# Signet overrides:
# QBIT_CHAIN=signet
# QBIT_CHAIN_FLAG=-signet
# QBIT_NODE_EXTRA_ARG=-signetchallenge=<your_signet_challenge_hex>
# QBIT_LISTEN=0
# QBIT_RPC_PORT=38352
# QBIT_P2P_PORT=38355
# QBIT_RPC_PORT_HOST=127.0.0.1:38352
# QBIT_P2P_PORT_HOST=127.0.0.1:38355
# QBIT_MINER_ADDRESS=auto
# CKPOOL_MINDIFF=<reviewed-share-floor>
# CKPOOL_STARTDIFF=<reviewed-starting-share-difficulty>
# CKPOOL_MAXDIFF=<optional-share-difficulty-cap>
#
# qbitd stays private by default. To intentionally run a reachable qbit peer,
# set QBIT_LISTEN=1 and publish QBIT_P2P_PORT_HOST=0.0.0.0:<p2p-port>.
#
# Optional live parent-chain overrides for AuxPoW operator mode:
# BITCOIN_RPC_HOST=<your_parent_node_host>
# BITCOIN_RPC_PORT=<your_parent_node_rpc_port>
# BITCOIN_RPC_USER=<your_parent_node_rpc_user>
# BITCOIN_RPC_PASSWORD=<your_parent_node_rpc_password>
# BITCOIN_MINER_ADDRESS=<your_bitcoin_payout_address>
#
# Local Bitcoin testnet4 parent-node example:
# BITCOIN_CHAIN_FLAG=-testnet4
# BITCOIN_RPC_PORT=48332
# BITCOIN_P2P_PORT=48333
# BITCOIN_RPC_PORT_HOST=127.0.0.1:48332
# BITCOIN_P2P_PORT_HOST=127.0.0.1:48333
# BITCOIN_DNSSEED=1
# BITCOIN_DISCOVER=0
# BITCOIN_NODE_EXTRA_ARGS=
# BITCOIN_MINER_ADDRESS=<your_bitcoin_testnet4_payout_address>
#
# Equivalent discovery override using the general extra-args hook:
# BITCOIN_NODE_EXTRA_ARGS="-dnsseed=1"
