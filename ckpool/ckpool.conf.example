# qbit-focused ckpool overlay.
# This is not a full upstream ckpool config. Merge these values into the
# config format used by your ckpool fork.

coin = qbit
rpc_url = http://127.0.0.1:8352
rpc_user = qbitrpc
rpc_password = change-this
payout_address = replace-with-your-qbit-p2mr-address
# Public qbit chains require P2MR payout addresses.
# For qbit signet, swap to rpc_url=http://127.0.0.1:38352 and payout_address=replace-with-your-signet-p2mr-address.
mainnet_p2pkh_prefix = 58
mainnet_p2sh_prefix = 63
mainnet_bech32_hrp = qb
coinbase_maturity = 1000
target_spacing_seconds = 60
permissionless_lane_spacing_seconds = 75
auxpow_lane_spacing_seconds = 300
max_block_weight = 2000000
witness_scale_factor = 1
auxpow_chain_id = 31430
# Prefer getblocktemplate.versionrollingmask from the connected qbitd.
# Use the current production fallback only when qbitd cannot advertise it.
version_mask = 1fffe000
